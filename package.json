{
  "name": "revornix-chrome-extension",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:main": "vite build --config vite.config.ts",
    "build:content": "vite build --config vite.config.content.ts",
    "build:merge": "mkdir -p dist && cp -r dist-main/* dist/ && cp dist-content/content.js dist/ && if [ -d dist-content/assets ]; then mkdir -p dist/assets && cp -r dist-content/assets/* dist/assets/; fi",
    "build": "pnpm build:main && pnpm build:content && pnpm build:merge",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lodash-es": "^4.18.1",
    "lucide-react": "^0.536.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vite-plugin-crx-mv3": "^0.1.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.39",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "globals": "^16.5.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.1"
  }
}
